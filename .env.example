## Global environment example for local development

# PostgreSQL connection (Docker local)
DATABASE_URL=postgresql://sui:sui@localhost:5432/deepbook_indexer

# Sui RPC (default: Testnet, uncomment Mainnet below if needed)
RPC_API_URL=https://fullnode.testnet.sui.io:443
# RPC_API_URL=https://fullnode.mainnet.sui.io:443

# DeepBookV3 package IDs (match the selected RPC)
# Testnet (default)
DEEPBOOK_PACKAGE_ID=0x9ae1cbfb7475f6a4c2d4d3273335459f8f9d265874c4d161c1966cdcbd4e9ebc
# Mainnet
# DEEPBOOK_PACKAGE_ID=0x00c1a56ec8c4c623a848b2ed2f03d23a25d17570b670c22106f336eb933785cc

# Indexer runtime
INDEXER_POLL_INTERVAL_MS=1000
INDEXER_RPC_TIMEOUT_MS=10000
RUST_LOG=info

# API server
API_LISTEN_ADDR=0.0.0.0:8080
LOG_LEVEL=info
